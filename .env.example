# ── 26AS Matcher v2.0 — Environment Configuration ────────────────────────────
# Copy this file to .env and fill in values for your environment.
# NEVER commit .env to version control.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="26AS Matcher"
APP_VERSION="2.0.0"
ALGORITHM_VERSION="v5.1"
DEBUG=false
ENVIRONMENT=development     # development | staging | production

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — zero install):
DATABASE_URL=sqlite+aiosqlite:///./reco.db
DATABASE_SYNC_URL=sqlite:///./reco.db

# Production (PostgreSQL — uncomment and fill):
# DATABASE_URL=postgresql+asyncpg://reco_user:STRONG_PASSWORD@localhost:5432/reco_db
# DATABASE_SYNC_URL=postgresql://reco_user:STRONG_PASSWORD@localhost:5432/reco_db

# ── Security (CHANGE ALL OF THESE IN PRODUCTION) ──────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Development (fakeredis — no Redis needed):
USE_FAKE_REDIS=true

# Production (real Redis — uncomment):
# USE_FAKE_REDIS=false
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER=redis://localhost:6379/0
# CELERY_BACKEND=redis://localhost:6379/1

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
AUDIT_LOG_DIR=./audit_logs
MAX_UPLOAD_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your frontend URL:
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Financial Year ─────────────────────────────────────────────────────────────
DEFAULT_FINANCIAL_YEAR=FY2023-24
